APP_API_KEY=dev-local-key
CORS_ORIGINS=["http://localhost:5173"]

DATABASE_URL=postgresql+asyncpg://uc1:uc1@localhost:5433/uc1_rag

AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=uc1-rag-index

AZURE_FOUNDRY_ENDPOINT=https://<your-foundry-resource>.openai.azure.com
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_API_VERSION=2024-10-21

GENERATION_MODEL_DEFAULT=deepseek-v3.2
GENERATION_MODEL_ALT=gpt-5.5

EMBEDDING_MODEL_DEFAULT=text-embedding-3-large
EMBEDDING_MODEL_ALT=text-embedding-3-small

RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.55
