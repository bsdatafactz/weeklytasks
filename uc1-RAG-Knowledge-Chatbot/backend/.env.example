APP_API_KEY=dev-local-key
CORS_ORIGINS=["http://localhost:5173"]

DATABASE_URL=postgresql+asyncpg://uc1:uc1@localhost:5433/uc1_rag

# Same Azure AI Search *service* as production is fine to share, but use a different
# *index name* for local dev (e.g. suffix "-local"). Each document's Postgres row and
# its Search chunks are created together in the same ingestion run and reference each
# other by id -- if local Docker and a deployed environment ever point at the same
# index, whichever one reindexes last overwrites the document ids the other's Postgres
# rows no longer match, and citation saves start failing silently (a real incident:
# see docs/design-doc.md).
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=uc1-rag-index-local

AZURE_FOUNDRY_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/openai/v1
AZURE_FOUNDRY_API_KEY=

GENERATION_MODEL_DEFAULT=gpt-5

EMBEDDING_MODEL_DEFAULT=text-embedding-3-large
EMBEDDING_MODEL_ALT=text-embedding-3-small

RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=2.0
